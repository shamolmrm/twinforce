{
  "name": "@twinforce/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seeds/index.ts",
    "seed-admin": "bun run src/scripts/seed-admin.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@supabase/supabase-js": "^2.50.0",
    "drizzle-orm": "^0.44.1",
    "hono": "^4.7.11",
    "ioredis": "^5.4.2",
    "minio": "^8.0.5",
    "nats": "^2.29.2",
    "stripe": "^17.7.0",
    "zod": "^3.24.2",
    "jose": "^5.10.0",
    "bcryptjs": "^3.0.2",
    "nodemailer": "^6.9.16",
    "uuid": "^11.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@sentry/node": "^9.2.0",
    "postgres": "^3.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.8.3"
  }
}
